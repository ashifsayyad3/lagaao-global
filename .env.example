# ─── APP ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:4200

# ─── DATABASE ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lagaao
DB_USER=lagaao_user
DB_PASS=changeme

# ─── REDIS ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_min_64_chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── EMAIL ────────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@lagaao.com

# ─── OTP / SMS ────────────────────────────────────────────────
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ─── STORAGE ──────────────────────────────────────────────────
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=ap-south-1
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# ─── PAYMENTS ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── AI ───────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── ELASTICSEARCH ────────────────────────────────────────────
ELASTIC_NODE=http://localhost:9200
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=
