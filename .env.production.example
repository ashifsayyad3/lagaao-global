# ─── APP ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://lagaao.com

# ─── DATABASE ─────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=lagaao
DB_USER=lagaao_user
DB_PASS=<strong_db_password>
DB_ROOT_PASS=<strong_root_password>

# ─── REDIS ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASS=<strong_redis_password>

# ─── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<64_char_hex_secret>
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<64_char_hex_refresh_secret>
JWT_REFRESH_EXPIRES_IN=7d

# ─── EMAIL ────────────────────────────────────────────────────
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=<smtp_api_key>
EMAIL_FROM=noreply@lagaao.com

# ─── STORAGE ──────────────────────────────────────────────────
STORAGE_DRIVER=s3
S3_BUCKET=lagaao-assets
S3_REGION=ap-south-1
AWS_ACCESS_KEY=<aws_access_key>
AWS_SECRET_KEY=<aws_secret_key>

# ─── PAYMENTS ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=<razorpay_secret>

# ─── AI ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── ELASTICSEARCH ────────────────────────────────────────────
ELASTIC_NODE=http://elasticsearch:9200
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=<elastic_password>
